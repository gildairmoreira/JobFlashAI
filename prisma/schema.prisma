// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Resume {
  id     String @id @default(cuid())
  userId String

  title       String?
  description String?

  photoUrl    String?
  colorHex    String  @default("#000000")
  borderStyle String  @default("squircle")
  templateId  String  @default("classic")
  fontFamily  String  @default("lato")
  summary     String?
  firstName   String?
  lastName    String?
  jobTitle    String?
  city        String?
  country     String?
  phone       String?
  email       String?
  socialLinks Json?   @default("[]")
  language             String?
  alternateLanguageData Json?

  workExperiences WorkExperience[]
  educations      Education[]
  skills          String[]
  customSections   CustomSection[]
  atsScore        ResumeAtsScore?
  jobFitSourced   JobFitGeneration[] @relation("SourceResume")
  jobFitOutputted JobFitGeneration?  @relation("OutputResume")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resumes")
}

model WorkExperience {
  id String @id @default(cuid())

  position    String?
  company     String?
  startDate   DateTime?
  endDate     DateTime?
  description String?

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_experiences")
}

model Education {
  id String @id @default(cuid())

  degree    String?
  school    String?
  startDate DateTime?
  endDate   DateTime?

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("educations")
}

model CustomSection {
  id String @id @default(cuid())

  title String?
  content String?

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("custom_sections")
}

enum Role {
  USER
  ADMIN
  MASTER_ADMIN
}

enum PlanType {
  FREE
  PRO
  MONTHLY
}

enum SubStatus {
  ACTIVE
  FROZEN
  BANNED
}

model UserSubscription {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  role                    Role     @default(USER)

  planType                PlanType @default(FREE)
  caktoTransactionId      String?  @unique // Cakto Payment or Subscription identifier
  status                  SubStatus @default(ACTIVE) // Can freeze/ban users

  currentPeriodEnd        DateTime? // Expiration for PRO; Null for MONTHLY or FREE

  transactions            Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_subscriptions")
}

model UserUsage {
  id     String @id @default(cuid())
  userId String @unique

  aiExperienceUses Int @default(0)
  aiSummaryUses    Int @default(0)
  aiCustomUses     Int @default(0)
  jobFitUsesThisMonth Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_usages")
}

model AiGenerationCache {
  id         String   @id @default(cuid())
  promptHash String   @unique @db.VarChar(64)
  result     String   @db.Text
  createdAt  DateTime @default(now())

  @@index([promptHash])
  @@map("ai_generation_cache")
}

model ResumeAtsScore {
  id        String   @id @default(cuid())
  userId    String
  resumeId  String   @unique
  score     Int
  details   Json     // { strengths, weaknesses, keyword_match, suggestions }

  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resume_ats_scores")
}

model JobFitGeneration {
  id              String   @id @default(cuid())
  userId          String
  sourceResumeId  String
  outputResumeId  String?  @unique
  jobDescription  String   @db.Text
  status          String   @default("pending") // pending | processing | done | error
  errorMessage    String?
  sectionsCompleted Int    @default(0)

  sourceResume    Resume   @relation("SourceResume", fields: [sourceResumeId], references: [id], onDelete: Cascade)
  outputResume    Resume?  @relation("OutputResume", fields: [outputResumeId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@map("job_fit_generations")
}

model Transaction {
  id                 String   @id @default(cuid())
  userId             String
  caktoTransactionId String   @unique
  amount             Float
  currency           String   @default("BRL")
  status             String   // PENDING, PAID, REFUSED, REFUNDED
  paymentMethod      String?  // pix, card, boleto
  customerEmail      String?
  customerName       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userSubscription   UserSubscription @relation(fields: [caktoTransactionId], references: [caktoTransactionId], map: "transaction_subscription_fkey")

  @@map("transactions")
}

model AnalyticEvent {
  id        String   @id @default(cuid())
  userId    String?
  event     String   // initiate_checkout, pix_gerado, purchase_approved, etc.
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("analytic_events")
}

model GlobalSetting {
  id                 String   @id @default("global")
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?  @default("Estamos em manutenção programada. Voltaremos em breve!")
  proPrice           Float    @default(19.90)
  monthlyPrice       Float    @default(49.90)

  updatedAt          DateTime @updatedAt

  @@map("global_settings")
}
